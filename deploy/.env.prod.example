# Production env for the Oracle deploy. Copy to deploy/.env.prod on the box and fill in.
#   cp deploy/.env.prod.example deploy/.env.prod   # then edit
# deploy/.env.prod is gitignored — never commit real secrets.

# --- required ---
NEO4J_PASSWORD=change-me-to-something-strong
OPENROUTER_API_KEY=sk-or-...            # powers the chatbot + embeddings

# --- public address ---
# A real domain you point at the VM's IP -> automatic HTTPS. Leave as :80 if you only
# have the IP for now (plain HTTP); switch to the domain later and re-up.
SITE_ADDRESS=:80

# --- Neo4j memory (12 GB free tier defaults; raise on a 24 GB PAYG box) ---
NEO4J_HEAP=3G
NEO4J_PAGECACHE=3G

# --- optional ---
NCBI_API_KEY=                           # raises NCBI rate limit 3->10 req/s

# --- models (defaults match .env.example; override only to swap models) ---
TEXT2CYPHER_MODEL=anthropic/claude-sonnet-4.6
SYNTHESIS_MODEL=anthropic/claude-sonnet-4.6
CITATION_CHECK_MODEL=anthropic/claude-haiku-4.5
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- feature flags / tunables (see .env.example for the full set) ---
METABOLITE_BRIDGE_ENABLED=false

# --- literature extraction + review dashboard (Feature 2, ADR-0013/0014) ---
# OFF by default (spends on NCBI+LLM). Set true to run the extractor AND to enable the
# /admin review dashboard's write actions (approve/reject/revert).
EXTRACTION_AGENT_ENABLED=false
# Gate for the /admin review dashboard. REQUIRED once EXTRACTION_AGENT_ENABLED=true on a
# public host — an empty token leaves /admin ungated at the app layer (Caddy basic_auth is
# only the second layer). The frontend sends it as the X-Admin-Token header.
ADMIN_TOKEN=
